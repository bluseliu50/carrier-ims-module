<?xml version="1.0" encoding="utf-8"?>
<!--
  Grants the privileged CarrierImsApplier app the signature|privileged permissions
  it needs. Without this file the priv-app install is rejected on strict builds
  (KernelSU/Magisk/APatch priv-app allowlist enforcement).
-->
<permissions>
    <privapp-permissions package="io.carrierims.applier">
        <permission name="android.permission.MODIFY_PHONE_STATE" />
        <permission name="android.permission.READ_PRIVILEGED_PHONE_STATE" />
        <permission name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    </privapp-permissions>
</permissions>
